NODE_ENV=production

# Seguridad del panel interno
ADMIN_USER=admin
ADMIN_PASSWORD=change_me

# Railway PostgreSQL interno. Railway lo inyecta al conectar el servicio Postgres.
DATABASE_URL=postgresql://user:password@host:port/database

# No usar DATABASE_PUBLIC_URL en la app productiva; es solo para conexiones externas puntuales.

# Opcional fase posterior: proxy a servicios externos
LUMI_API_BASE=https://lumi-klinge-bot-production.up.railway.app
LUMI_ADMIN_KEY=change_me

# Dominio final sugerido
ALLOWED_ORIGIN=https://app.klinge.cl
